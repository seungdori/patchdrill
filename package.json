{
  "name": "patchdrill",
  "version": "0.1.0",
  "description": "A local-first CI drill for proving AI-generated and human patches are safe before merge.",
  "type": "module",
  "bin": {
    "patchdrill": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schemas",
    "docs",
    "examples",
    "fixtures",
    ".patchdrill.yml",
    "README.md",
    "LICENSE",
    "action.yml",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run build && npm test",
    "prepare": "npm run build",
    "prepack": "npm run check"
  },
  "keywords": [
    "ai-coding",
    "ci",
    "developer-tools",
    "git",
    "code-review",
    "testing",
    "agentic-coding",
    "evidence",
    "sarif",
    "codeowners",
    "monorepo",
    "turborepo",
    "nx",
    "supply-chain",
    "github-actions"
  ],
  "author": "PatchDrill contributors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seungdori/patchdrill.git"
  },
  "bugs": {
    "url": "https://github.com/seungdori/patchdrill/issues"
  },
  "homepage": "https://github.com/seungdori/patchdrill#readme",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "ajv": "^8.20.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
