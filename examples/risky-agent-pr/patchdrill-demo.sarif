        {
          "ruleId": "file.lockfile",
          "level": "note",
          "message": {
            "text": "Dependency lockfile changed: @acme/payments changed from 4.2.0 to 4.3.0. Remediation: Review release notes and verify transitive dependency impact."
          },
          "locations": [
            {
              "physicalLocation": {
