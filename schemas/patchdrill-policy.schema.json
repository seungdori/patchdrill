{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://patchdrill.dev/schemas/patchdrill-policy.schema.json",
  "title": "PatchDrill Policy",
  "description": "Policy-as-code configuration for PatchDrill.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "ignoredPaths": {
      "$ref": "#/$defs/stringArray"
    },
    "ignore": {
      "$ref": "#/$defs/stringArray"
    },
    "failOn": {
      "$ref": "#/$defs/severity"
    },
    "maxRisk": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "requiredCommands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policyCommand"
      },
      "default": []
    },
    "optionalCommands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policyCommand"
      },
      "default": []
    },
    "rules": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/policyRule"
      },
      "default": []
    }
  },
  "$defs": {
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "stringArray": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "pathPattern": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        }
      ]
    },
    "policyCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "policyRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "severity"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "path": {
          "$ref": "#/$defs/pathPattern"
        },
        "paths": {
          "$ref": "#/$defs/pathPattern"
        },
        "detail": {
          "type": "string"
        },
        "remediation": {
          "type": "string"
        },
        "weight": {
          "type": "number"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      }
    }
  }
}
